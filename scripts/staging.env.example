# Copy to staging.env in repo root (gitignored) and fill with real values.
# All miners and the validator share this bucket; miners use separate key prefixes
# via R2_PREFIXES in run_operator_localnet_matrix.sh (default: miners/m1_karpathy, ...).

export R2_ACCOUNT_ID=""
export R2_BUCKET_NAME=""
export R2_S3_ENDPOINT=""
export R2_ACCESS_KEY_ID=""
export R2_SECRET_ACCESS_KEY=""
# Optional: only for real AWS-compatible temporary credentials. Standard R2 S3 tokens
# use access key + secret only — do NOT set R2_TOKEN unless you also set:
#   export R2_USE_SESSION_TOKEN=1
# export R2_TOKEN=""
# export R2_USE_SESSION_TOKEN=0
#
# Stray AWS_SESSION_TOKEN in the shell is cleared for boto3 when session token is off.

# Vision-language model (pick one path — no mock servers)
# In-process Hugging Face Qwen2-VL (recommended for serious runs; needs GPU for throughput):
# export MINER_VLM_HF_MODEL="Qwen/Qwen2-VL-2B-Instruct"
# export MINER_VLM_HF_DEVICE=""          # auto: cuda > mps > cpu
# export MINER_VLM_HF_DTYPE="auto"       # auto | float32 | float16 | bfloat16
# export MINER_VLM_HF_MAX_NEW_TOKENS="384"
# Or OpenAI-compatible HTTP (vLLM / LM Studio hosting the same model class):
# export MINER_VLM_OPENAI_BASE_URL="http://127.0.0.1:1234/v1"
# export MINER_VLM_OPENAI_API_KEY=""
# export MINER_VLM_OPENAI_MODEL="Qwen/Qwen2-VL-2B-Instruct"

# Chain (localnet defaults)
# export CHAIN_ENDPOINT="ws://127.0.0.1:9944"
# export NETUID="2"
# export WALLET_PATH="$HOME/.bittensor/wallets"

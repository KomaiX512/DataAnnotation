# CPU-only image for isolated miner checkpoint evaluation (dual-flywheel).
# Build: docker build -f Dockerfile.flywheel-yolo-eval -t flywheel-yolo-eval:local .
# Validator: --neuron.flywheel_model_eval_docker_image flywheel-yolo-eval:local

FROM python:3.11-slim

RUN pip install --no-cache-dir ultralytics pillow && \
    pip install --no-cache-dir torch torchvision --index-url https://download.pytorch.org/whl/cpu

COPY scripts/flywheel_yolo_docker_worker.py /app/worker.py

ENTRYPOINT ["python", "/app/worker.py"]

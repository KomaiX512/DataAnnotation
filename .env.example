# ==============================================================================
# DECENTRALIZED DATA ANNOTATION SUBNET - CONFIGURATION
# ==============================================================================
# Copy this file to .env (e.g. `cp .env.example .env`) and adjust settings.
# Optional variables are commented out with default placeholders.

# ===== SUBNET =====
NETUID=1
SUBTENSOR_NETWORK=localnet
SUBTENSOR_CHAIN_ENDPOINT=ws://127.0.0.1:9944

# ===== WALLET =====
WALLET_NAME=default
WALLET_HOTKEY=default

# ===== CLOUDFLARE R2 (S3-Compatible Storage) =====
# Required for upload and retrieval of annotations.
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
# Note: You can use R2_ENDPOINT_URL or R2_S3_ENDPOINT (both are supported).
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=annotation-subnet
# Optional settings:
# R2_ACCOUNT_ID=
# R2_PUBLIC_BUCKET_URL=
# R2_PRESIGNED_EXPIRES_SECONDS=7200

# ===== MINER CONFIG =====
# Backend choice: self_hosted | yolo_local | openai_vision
MINER_MODEL_BACKEND=self_hosted
MINER_ANNOTATION_WORKSPACE=./artifacts/miner_annotation
MINER_R2_PREFIX=miners/annotations
# MINER_SKIP_TRAINING=0
# MINER_FORCE_RETRAIN=0

# --- Settings for backend: self_hosted ---
# Point to your custom REST API server.
# Start reference server: `python server.py --host 127.0.0.1 --port 8081`
SELF_HOSTED_TRAIN_URL=http://localhost:8081/train
SELF_HOSTED_INFER_URL=http://localhost:8081/infer
# SELF_HOSTED_API_KEY=
# SELF_HOSTED_POLL_INTERVAL_SECONDS=30

# --- Settings for backend: yolo_local ---
# Pretrained Ultralytics weights to start training from.
# YOLO_MODEL_PATH=yolov8n.pt
# YOLO_EPOCHS=10
# YOLO_IMGSZ=640
# YOLO_BATCH=16

# --- Settings for backend: openai_vision ---
# Fine-tune and query GPT-4o models. Warning: Can incur high API costs!
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# OPENAI_BASE_MODEL=gpt-4o-2024-08-06
# OPENAI_N_EPOCHS=3
# OPENAI_BATCH_SIZE=1
# OPENAI_LEARNING_RATE_MULTIPLIER=1.8

# ===== VALIDATOR CONFIG =====
# -----------------------------------------------------------------------
# DATASET: Climate MRV Satellite Imagery (Phase 1 Testnet default)
# -----------------------------------------------------------------------
# The validator uses Climate MRV satellite imagery (Sentinel-2 + Hansen
# golden samples) by default.  To switch to a HuggingFace dataset, set
# VALIDATOR_GOLDEN_DATASET to any HuggingFace dataset ID.
VALIDATOR_GOLDEN_DATASET=climate_mrv
VALIDATOR_GOLDEN_RATIO=0.30
VALIDATOR_GOLDEN_SPLIT_SEED=20260601

# --- Google Earth Engine (GEE) settings ---
# Optional: set your GEE cloud project if using service-account auth.
# Leave empty to use personal earthengine auth (gcloud / EE CLI).
# GEE_PROJECT=my-gcp-project-id

# Number of Sentinel-2 annotation-pool chips downloaded per validator run.
# Reduce if GEE rate limits are hit (default: 200).
CLIMATE_MRV_N_RAW_CHIPS=200

# Number of Hansen/ESA golden-set chips (validator-only, never served raw).
CLIMATE_MRV_N_GOLDEN_CHIPS=60

# --- Offline / CI fallback ---
# If GEE is unavailable, the validator loads pre-exported chips from this dir.
# Directory layout: <dir>/raw/*.jpg, <dir>/golden/<class>/*.jpg, <dir>/golden_labels.json
# Leave empty to use the bundled sample chips at data/climate_mrv/samples/.
# CLIMATE_MRV_FALLBACK_DIR=data/climate_mrv/samples
# CLIMATE_MRV_FALLBACK_GOLDEN_MANIFEST=

# --- Legacy COCO / HuggingFace override (keep commented for testnet) ---
# VALIDATOR_COCO_MANIFEST=./artifacts/localnet/coco200/manifest.json
# VALIDATOR_ANNOTATION_DATASET=
VALIDATOR_ANNOTATION_SPLIT=train
VALIDATOR_ANNOTATION_MAX_PER_DATASET=512

# Validator behavior settings
VALIDATOR_IMAGE_CACHE_ROOT=./data/flywheel/image_cache
# VALIDATOR_IMAGE_SERVING_BASE_URL=
VALIDATOR_REQUEST_SIZE=0
VALIDATOR_GOLDEN_INJECTION_PER_REQUEST=0
VALIDATOR_COMMERCIAL_DATASET_PREFIX=file:///home/komail/bittensor-subnet-template-1/artifacts/commercial_dataset
VALIDATOR_COMMERCIAL_EXPORT_EVERY=10
COMMERCIAL_DRAW_BOXES=true
COMMERCIAL_ANNOTATED_IMAGE_PREFIX=commercial/annotated-images/
VALIDATOR_SAMPLE_SIZE=50
VALIDATOR_TIMEOUT=10
# VALIDATOR_ANNOTATION_TIMEOUT=0
# VALIDATOR_NUM_CONCURRENT_FORWARDS=1
# VALIDATOR_FORWARD_STEP_SLEEP_SECONDS=0
# VALIDATOR_DISABLE_SET_WEIGHTS=0
# VALIDATOR_AXON_OFF=0

# ===== ADVANCED & TESTING =====
# Force setting weights on localnet (bypasses commit-reveal restrictions)
FORCE_LOCAL_SET_WEIGHTS=0
# Run mock wallet/subtensor (for unit tests only)
TEST_MODE=0

# ===== SINGLE-MINER FALLBACK =====
# When only one miner responds, adopt their annotation if their reliability
# meets the threshold instead of escalating.  Enabled by default to prevent
# early-adopter deadlock where every image is discarded.
FALLBACK_SINGLE_MINER_ENABLED=1
FALLBACK_SINGLE_MINER_MIN_RELIABILITY=0.3
# FALLBACK_SINGLE_MINER_AGGREGATION_LABEL=single_miner_fallback_v1
